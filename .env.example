#app
APP_NAME=payment-service
APP_HOST=0.0.0.0
APP_PORT=8000

#db
DB_HOST=db
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://payments:payments@db:5432/payments


#rabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_PORT=5672
RABBITMQ_ADDITIONAL_ERL="-rabbit disk_free_limit 2147483648"

#additional_params
API_KEY=super-secret-api-key
WEBHOOK_TIMEOUT=5
MAX_RETRIES=3
BACKOFF_BASE_SECONDS=2